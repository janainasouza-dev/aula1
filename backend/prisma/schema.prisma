-- 1. Tabela de Usuários (Alunos e Professores)
CREATE TABLE usuarios (
    id SERIAL PRIMARY KEY,
    matricula VARCHAR(20) UNIQUE NOT NULL,
    nome VARCHAR(100) NOT NULL,
    email VARCHAR(100) UNIQUE NOT NULL,
    senha_hash VARCHAR(255) NOT NULL,
    tipo VARCHAR(20) CHECK (tipo IN ('aluno', 'professor')),
    ativo BOOLEAN DEFAULT TRUE,
    criado_em TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);

-- 2. Tabela de Disciplinas
CREATE TABLE disciplinas (
    id SERIAL PRIMARY KEY,
    codigo VARCHAR(10) UNIQUE NOT NULL,
    nome VARCHAR(100) NOT NULL,
    professor_id INTEGER REFERENCES usuarios(id),
    vagas_total INTEGER DEFAULT 40,
    horario VARCHAR(50),
    local_aula VARCHAR(50)
);

-- 3. Tabela de Matrículas (Liga Aluno à Disciplina)
CREATE TABLE matriculas (
    id SERIAL PRIMARY KEY,
    aluno_id INTEGER REFERENCES usuarios(id),
    disciplina_id INTEGER REFERENCES usuarios(id),
    semestre VARCHAR(10) NOT NULL,
    status VARCHAR(20) DEFAULT 'cursando', -- aprovado, reprovado, cancelado
    data_matricula TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);

-- 4. Tabela de Notas
CREATE TABLE notas (
    id SERIAL PRIMARY KEY,
    matricula_id INTEGER REFERENCES matriculas(id) ON DELETE CASCADE,
    nota_av1 DECIMAL(4,2),
    nota_av2 DECIMAL(4,2),
    nota_final DECIMAL(4,2),
    frequencia INTEGER,
    atualizado_em TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);